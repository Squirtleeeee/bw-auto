# 抢票参数
PRE_FIRE_MS=200
GRAB_INTERVAL_MS=300
GRAB_MAX_ATTEMPTS=15
NUM_PREWARM_CONNECTIONS=3

# Web 界面
WEB_HOST=127.0.0.1
WEB_PORT=8765
