# Bilibili 会员购抢票配置（可选，配合 bw-auto grab 非交互模式）

# 实名信息（也可在交互/Web 中选择）
BUYER_NAME=
BUYER_TEL=
BUYER_ID_CARD=

# 目标商品（非交互时填写）
TARGET_PROJECT_ID=
TARGET_SCREEN_ID=
TARGET_SKU_ID=
TARGET_BUY_NUM=1
TARGET_SALE_TIME=

# 脚本启动时间（留空=立即进入准备阶段）
